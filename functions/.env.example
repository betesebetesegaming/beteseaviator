# Copy to `.env` before deploying functions (never commit `.env`).
MODEMPAY_BASE_URL=https://api.modempay.com
MODEMPAY_SECRET_KEY=
MODEMPAY_PUBLIC_KEY=
MODEMPAY_WEBHOOK_SECRET=
MODEMPAY_MERCHANT_NAME=Betese Aviator
WEB_API_KEY=
WAVE_WEBHOOK_SECRET=legacy-unused
AFRIMONEY_WEBHOOK_SECRET=legacy-unused
APS_WEBHOOK_SECRET=legacy-unused
QMONEY_WEBHOOK_SECRET=legacy-unused

# Africell SMS (OTP functions — Gambian customer signup / withdrawal verification)
# Per Africell PDF: POST https://host:port/api/sendsms?sender=...&msisdn=... (Basic auth, plain-text body)
AFRICELL_SMS_URL=https://esme.africell.gm:5991
AFRICELL_SMS_USERNAME=
AFRICELL_SMS_PASSWORD=
AFRICELL_SMS_SENDER=Betese
OTP_HASH_SALT=

# Fallback OTP relay when Aviator Africell egress is blocked (uses betesepmu Cloud Functions)
PMU_OTP_API_BASE_URL=https://us-central1-betesepmu-4ffc7.cloudfunctions.net

# Smart Bonus AI — optional. Set to enable Claude-powered bonus recommendations
# (Admin → Smart Bonus → "Use Claude AI"). Falls back to rule-based if unset.
ANTHROPIC_API_KEY=

# QTech Common Wallet — inbound wallet auth (QTech calls our wallet). Shared secret.
QT_PASS_KEY=
# QTech launch API — outbound (we call QTech). From your QTech onboarding email.
QT_API_BASE_URL=
QT_OPERATOR_ID=
QT_API_PASSWORD=
