rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function role() {
      return request.auth.token.role;
    }

    function isAdmin() {
      return signedIn() && role() == 'admin';
    }

    function isAgent() {
      return signedIn() && role() in ['super_agent', 'sub_agent'];
    }

    function isPlayer() {
      return signedIn() && role() == 'player';
    }

    function userDoc(u) {
      return get(/databases/$(database)/documents/users/$(u)).data;
    }

    function isActiveUser(u) {
      return userDoc(u).status == 'active';
    }

    // Public game lobby + referral slugs (read-only from clients)
    match /games/{gameId} {
      allow read: if resource.data.status == 'active' || isAdmin();
      allow write: if false;
    }

    match /slugs/{slug} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{userId} {
      allow read: if isAdmin()
        || (signedIn() && uid() == userId)
        || (isAgent() && userId in resource.data.ancestors);
      allow write: if false;
    }

    match /wallets/{userId} {
      allow read: if signedIn() && (
        uid() == userId
        || isAdmin()
        || (isAgent() && (
          userId == uid()
          || userDoc(userId).parentId == uid()
          || uid() in userDoc(userId).ancestors
        ))
      );
      allow write: if false;
    }

    match /transactions/{txnId} {
      allow read: if signedIn() && (
        resource.data.userId == uid()
        || isAdmin()
        || (isAgent() && (
          resource.data.userId == uid()
          || userDoc(resource.data.userId).parentId == uid()
          || uid() in userDoc(resource.data.userId).ancestors
        ))
      );
      allow write: if false;
    }

    match /gameSessions/{sessionId} {
      allow read: if signedIn()
        && (resource.data.playerId == uid() || isAdmin());
      allow write: if false;
    }

    match /commissions/{commissionId} {
      allow read: if signedIn()
        && (resource.data.agentId == uid() || isAdmin());
      allow write: if false;
    }

    match /paymentRequests/{requestId} {
      allow read: if signedIn()
        && (resource.data.userId == uid() || isAdmin());
      allow write: if false;
    }

    /** ModemPay deposit/withdrawal tracking — same collections as betesepmu. */
    match /deposit_requests/{requestId} {
      allow read: if signedIn()
        && (resource.data.customer_id == uid() || isAdmin());
      allow create: if signedIn()
        && isActiveUser(uid())
        && request.resource.data.customer_id == uid()
        && request.resource.data.status == 'Pending';
      allow update, delete: if false;
    }

    match /withdrawal_requests/{requestId} {
      allow read: if signedIn()
        && (resource.data.user_id == uid() || isAdmin());
      allow create: if signedIn()
        && isActiveUser(uid())
        && request.resource.data.user_id == uid()
        && request.resource.data.status == 'Pending';
      allow update, delete: if false;
    }

    match /settings/{docId} {
      allow read: if isAdmin() || docId == 'platform' || docId == 'lobbyPromos' || docId == 'lobbyLayout' || docId == 'demoAccounts';
      allow write: if false;
    }

    match /dailyStats/{date} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /stats/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /agentDailyGgr/{docId} {
      allow read: if isAdmin()
        || (isAgent() && resource.data.agentId == uid());
      allow write: if false;
    }

    match /phones/{phone} {
      allow read, write: if false;
    }

    /** OTP codes — Cloud Functions only (Africell SMS verification). */
    match /otp_codes/{phone} {
      allow read, write: if false;
    }

    /** Recent OTP verifications — Cloud Functions only. */
    match /otp_verified/{phone} {
      allow read, write: if false;
    }

    match /referral_rewards/{rewardId} {
      allow read: if signedIn()
        && (resource.data.referrerId == uid() || isAdmin());
      allow write: if false;
    }

    match /referralInvites/{inviteId} {
      allow read: if signedIn()
        && (resource.data.referrerId == uid() || inviteId == uid() || isAdmin());
      allow write: if false;
    }

    match /playerRefs/{code} {
      allow read: if true;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
