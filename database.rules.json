{
  "rules": {
    "rounds": {
      "$gameId": {
        "current": { ".read": true, ".write": false },
        "history": { ".read": true, ".write": false },
        ".write": false
      }
    },
    "payments": {
      ".read": true,
      ".write": true
    },
    "presence": {
      "$uid": {
        ".read": "auth != null && auth.token.role == 'admin'",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    ".read": false,
    ".write": false
  }
}
