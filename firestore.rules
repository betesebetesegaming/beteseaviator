rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function role() {
      return request.auth.token.role;
    }

    function isAdmin() {
      return signedIn() && role() == 'admin';
    }

    function isAgent() {
      return signedIn() && role() in ['super_agent', 'sub_agent'];
    }

    function isPlayer() {
      return signedIn() && role() == 'player';
    }

    function userDoc(u) {
      return get(/databases/$(database)/documents/users/$(u)).data;
    }

    function isActiveUser(u) {
      return userDoc(u).status == 'active';
    }

    // Public game lobby + referral slugs (read-only from clients)
    match /games/{gameId} {
      allow read: if resource.data.status == 'active' || isAdmin();
      allow write: if false;
    }

    match /slugs/{slug} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{userId} {
      allow read: if isAdmin()
        || (signedIn() && uid() == userId)
        || (isAgent() && userId in resource.data.ancestors);
      allow write: if false;
    }

    match /wallets/{userId} {
      allow read: if signedIn() && (uid() == userId || isAdmin());
      allow write: if false;
    }

    match /transactions/{txnId} {
      allow read: if signedIn()
        && (resource.data.userId == uid() || isAdmin());
      allow write: if false;
    }

    match /gameSessions/{sessionId} {
      allow read: if signedIn()
        && (resource.data.playerId == uid() || isAdmin());
      allow write: if false;
    }

    match /commissions/{commissionId} {
      allow read: if signedIn()
        && (resource.data.agentId == uid() || isAdmin());
      allow write: if false;
    }

    match /paymentRequests/{requestId} {
      allow read: if signedIn()
        && (resource.data.userId == uid() || isAdmin());
      allow write: if false;
    }

    match /settings/{docId} {
      allow read: if isAdmin() || docId == 'platform';
      allow write: if false;
    }

    match /stats/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /agentDailyGgr/{docId} {
      allow read: if isAdmin()
        || (isAgent() && resource.data.agentId == uid());
      allow write: if false;
    }

    match /phones/{phone} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
